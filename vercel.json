{
  "version": 2,
  "name": "graftai-frontend",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "installCommand": "cd frontend && npm install",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://graftai.onrender.com",
    "NEXT_PUBLIC_API_BASE_URL": "https://graftai.onrender.com/api/v1",
    "NEXT_PUBLIC_APP_URL": "https://www.graftai.tech",
    "NEXT_PUBLIC_BACKEND_URL": "https://graftai.onrender.com"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
