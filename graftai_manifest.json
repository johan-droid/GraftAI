{
  "project": {
    "name": "GraftAI",
    "version": "1.0.0-rc1",
    "description": "Premium Strategy & Ops Intelligence Platform (AI-First Scheduling)",
    "environment": "production"
  },
  "stack": {
    "backend": {
      "language": "Python 3.11+",
      "framework": "FastAPI",
      "server": "Uvicorn/Gunicorn",
      "port": 8000,
      "services": ["SendGrid/SMTP (Google)", "Arq Worker", "Redis", "Neon Postgres"]
    },
    "frontend": {
      "language": "TypeScript / React",
      "framework": "Next.js 16 (Turbopack)",
      "styling": "Vanilla CSS / Glassmorphism",
      "port": 3000,
      "auth": "Standalone Better Auth"
    }
  },
  "integrations": {
    "active": ["Google Calendar", "Microsoft Graph", "Google SMTP"],
    "planned": ["Slack", "Zoom", "Cal.com", "Vector Memory (RAG)"]
  },
  "entry_points": {
    "api_root": "/api/v1",
    "auth_root": "/api/auth",
    "dashboard": "/dashboard",
    "settings": "/dashboard/settings"
  },
  "infrastructure": {
    "hosting": "Render (PaaS)",
    "database": "Neon Serverless Postgres",
    "cache": "Upstash Redis",
    "background_tasks": "Arq"
  }
}
