# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GraftAI — AI-Powered Scheduling Platform
# Environment Configuration (Copy to .env and fill in actual values)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ENVIRONMENT & DEPLOYMENT
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Environment mode: development, staging, production
ENV=development

# Debug mode (ALWAYS false in production)
DEBUG=false

# Backend server port
PORT=8000

# Backend URL (used for dynamic OAuth redirects in prod e.g., https://your-app.onrender.com)
BACKEND_URL=http://localhost:8000
APP_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend URL (for CORS and OAuth redirects e.g., https://your-site.vercel.app)
FRONTEND_URL=http://localhost:3000

# Optional trusted host patterns for FastAPI TrustedHostMiddleware
# Use comma-separated hostnames or wildcard domains in production.
TRUSTED_HOSTS=localhost,127.0.0.1,*.graftai.tech

# API Base URL (for frontend to communicate with backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@localhost:5432/graftai
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/graftai

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECURITY & AUTHENTICATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# =============================================================================
# CRITICAL: JWT Secret Key
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be changed in production - application will refuse to start with default keys
# Minimum 32 characters (256 bits of entropy) required
SECRET_KEY=change-me-in-production-generate-with-secrets-token-urlsafe

# JWT secret used by backend auth flows.
JWT_SECRET=REPLACE_ME_JWT_SECRET

# Supported auth methods for this deployment
AUTH_METHODS=sso,passwordless,mfa

# Better Auth frontend integration
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# NextAuth / Auth.js configuration
NEXTAUTH_SECRET=REPLACE_ME_NEXTAUTH_SECRET
AUTH_SECRET=REPLACE_ME_AUTH_SECRET
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# JWT Algorithm (do not change unless you know what you're doing)
ALGORITHM=HS256

# =============================================================================
# Token Expiration (reduced for security - was 1 week, now 15 minutes)
# =============================================================================
# Access token expiration in minutes (default: 15, max recommended: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration in days (default: 7, max recommended: 30)
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Multi-Factor Authentication (MFA/TOTP)
# =============================================================================
# Encryption key for TOTP secrets (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# Optional - if not set, a random key will be generated on each restart (not recommended for production)
TOTP_ENCRYPTION_KEY=

# MFA issuer name displayed in authenticator apps
MFA_ISSUER_NAME=GraftAI

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI & LLM MODELS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenAI API Key
OPENAI_API_KEY=

# Groq API Key (alternative LLM provider)
GROQ_API_KEY=

# Vector database configuration
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX=

# Default LLM model
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, llama-3.3-70b-versatile
LLM_MODEL=gpt-4o-mini

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GOOGLE CALENDAR INTEGRATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth redirect URI (must match Google Cloud Console)
# In production, use the exact callback registered in Google Cloud.
# Example for Render: https://graftai.onrender.com/api/v1/auth/google/callback
# If this is not set, it will default to BACKEND_URL + /api/v1/auth/google/callback.
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MICROSOFT CALENDAR INTEGRATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Microsoft Entra ID credentials (from Azure Portal)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Microsoft OAuth redirect URI (must match Azure Portal)
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APPLE CALENDAR INTEGRATION (iCloud)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Apple Sign In credentials (from https://developer.apple.com/account/resources/)
# Required for Sign In with Apple OAuth
APPLE_CLIENT_ID=com.yourcompany.yourserviceid  # e.g., com.gyraft.gyraftai
APPLE_TEAM_ID=ABC123DEF4  # 10-character Team ID from Apple Developer
APPLE_KEY_ID=DEF456GHI7  # 10-character Key ID from Apple Developer

# Apple private key content (full PEM format, including BEGIN/END lines)
# Generate at: https://developer.apple.com/account/resources/authkeys/list
APPLE_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nMHQCAQEEIB...your key...\n-----END EC PRIVATE KEY-----"

# Apple OAuth redirect URI
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/apple/callback

# Note: For CalDAV calendar sync, users must generate an App-Specific Password
# at https://appleid.apple.com after signing in with Apple

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GDPR COMPLIANCE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Data Protection Officer (DPO) contact information
DPO_EMAIL=dpo@graftai.com
DPO_NAME=Data Protection Officer
DPO_PHONE=

# Supervisory authority contact (for breach notifications)
SUPERVISORY_AUTHORITY_EMAIL=
SUPERVISORY_AUTHORITY_NAME=Data Protection Commission (Ireland)

# Data retention schedule settings
RETENTION_AUTO_APPLY=true
RETENTION_SCHEDULE_CRON=0 2 * * *  # Daily at 2 AM UTC

# DSR processing settings
DSR_DEADLINE_DAYS=30
DSR_IDENTITY_VERIFICATION_EXPIRY_HOURS=24

# Breach notification settings
BREACH_SUPERVISORY_DEADLINE_HOURS=72
BREACH_NOTIFICATION_EMAIL_FROM=gdpr@graftai.com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CACHE & BACKGROUND JOBS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Redis connection URL (for caching and background tasks)
REDIS_URL=redis://localhost:6379/0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PAYMENT PROCESSING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Stripe (for global users - recommended)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Razorpay (for Indian users - alternative)
RAZORPAY_KEY_ID=rzp_test_dummy
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Payment operation mode controls whether real gateways are used, sandbox simulation is allowed,
# or payments are disabled entirely. Values: disabled | test | production
# - disabled: payments disabled; show request/manual upgrade UI
# - test: sandbox mode; use test keys or simulated flows; simulation endpoints enabled
# - production: live mode; simulation disabled
PAYMENT_MODE=test

# Optional: expose a client-visible build-time flag for Next.js builds (overrides API at build-time)
# Example: NEXT_PUBLIC_PAYMENT_MODE=test
NEXT_PUBLIC_PAYMENT_MODE=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL SERVICE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Resend API Key (for transactional email)
RESEND_API_KEY=

# Email configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@graftai.dev
SMTP_FROM_NAME="GraftAI Notification Service"
SMTP_USE_TLS=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OBSERVABILITY & MONITORING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Sentry error tracking DSN
SENTRY_DSN=

# Sentry environment
SENTRY_ENVIRONMENT=development

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AWS (if using S3 for file storage)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=us-east-1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FEATURE FLAGS & CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable AI features
AI_ENABLED=true

# Enable calendar sync
CALENDAR_SYNC_ENABLED=true

# Maximum file upload size (in MB)
MAX_UPLOAD_SIZE_MB=10
