```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.production
.env.production.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Local SQLite databases
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Coverage reports
coverage/
htmlcov/
.coverage

# Editors
.vscode/
.idea/

# System files
.DS_Store
Thumbs.db

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/
.coverage
nosetests.xml
coverage.xml
*.cover
*.log
.git/

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Build outputs
dist/
build/
target/
*.min.js
*.min.css

# Production and deployment artifacts
*.prod
*.production
*.stage
*.staging
docker-compose.prod.yml
Dockerfile.prod
.vercel/

# Frontend build artifacts and compiled source outputs
frontend/.next/
frontend/out/
frontend/src/**/*.js
frontend/src/**/*.jsx
frontend/src/**/*.js.map

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```