hadow-lg active:scale-95\">\r\n                Connect Now\r\n              </button>\r\n            </Link>\r\n          </div>\r\n\r\n          {/* Proactive AI Suggestion */}\r\n          {aiSuggestion && (\r\n            <div className=\"mt-4 p-3 rounded-xl border border-primary/20 bg-primary/5\">\r\n              <p className=\"text-xs text-primary font-medium flex items-center gap-1 mb-1\"><Sparkles className=\"w-3 h-3\" /> AI Suggestion</p>\r\n              <p className=\"text-sm text-slate-300\">{aiSuggestion}</p>\r\n            </div>\r\n          )}\r\n        </motion.div>\r\n      </div>\r\n    </motion.div>\r\n  );\r\n}\r\n\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\GraftAI\\frontend\\src\\app\\dashboard\\plugins\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\GraftAI\\frontend\\src\\app\\dashboard\\settings\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\GraftAI\\frontend\\src\\app\\layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\GraftAI\\frontend\\src\\app\\not-found.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\GraftAI\\frontend\\src\\app\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'AnimatePresence' is defined but never used.","line":5,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":33,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"AnimatePresence"},"fix":{"range":[98,115],"text":""},"desc"