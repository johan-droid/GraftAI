# ── GRAFTAI BACKEND ENVIRONMENT EXAMPLE ──

# --- CORE ---
ENV=development
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT=100/minute
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# --- DATABASE ---
# Backend (asyncpg format for modern FastAPI/SQLAlchemy apps)
# Example: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=your-database-url-with-asyncpg

# --- REDIS (Upstash or Local) ---
REDIS_URL=redis://localhost:6379/0

# --- SECURITY & AUTH ---
SECRET_KEY=generate-a-long-random-string
JWT_SECRET=generate-another-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_METHODS=sso,passwordless,mfa

# --- AI & LLM (Groq & Sovereign Memory) ---
# Primary reasoning engine
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
# Optional fallback (Used for embeddings if not using local fallback)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Sovereign Translation (Local Embeddings for privacy/cost)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- VECTOR DATABASE (Pinecone) ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=graft-ai-memory
# Namespace strategy for SaaS isolation (Default: org_{org_id})
VECTOR_DB_NAMESPACE_PREFIX=org_

# --- EXTERNAL INTEGRATIONS ---
CALCOM_API_URL=https://api.cal.com/v1
CALCOM_API_KEY=your-calcom-api-key

# --- PERSISTENT INTEGRATIONS (OAuth 2.0) ---
# Google Calendar (Strong Connection)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft Graph (Outlook/Teams)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Zoom Meeting (S2S or OAuth)
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# --- NOTIFICATION ENGINE ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=GraftAI
SMTP_USE_TLS=true
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-api-key

# --- SSO PROVIDERS ---
# GitHub / Generic OAuth2
OAUTH2_CLIENT_ID=your-id
OAUTH2_CLIENT_SECRET=your-secret
OAUTH2_REDIRECT_URI=http://localhost:8000/auth/sso/callback

# --- FIDO2 ---
FIDO2_RP_ID=localhost
FIDO2_RP_NAME=GraftAI
FIDO2_ORIGIN=http://localhost:3000
