# Example backend .env (no secrets)
# Copy this to backend/.env locally and fill in secrets. Do NOT commit real secrets.

ENV=development
DEBUG=true
PORT=8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT=100/minute
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Local development DB defaults (use SQLite for quick local dev)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# For production, set a Postgres connection string in a secrets store or via
# environment variables (do not commit). Example:
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

REDIS_URL=redis://redis:6379/0

# Security (provide strong secrets via env or secret manager)
SECRET_KEY=
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_METHODS=sso,passwordless,mfa

# AI / Integrations (placeholders only)
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Vector DB placeholders
PINECONE_API_KEY=
PINECONE_ENV=us-west1-gcp
PINECONE_INDEX=nextgen-scheduler

# External integrations (placeholders)
CALCOM_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=GraftAI Notification Service
SMTP_USE_TLS=true

# SSO placeholders
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTH_URL=
OAUTH2_TOKEN_URL=
OIDC_USERINFO_URL=
OAUTH2_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# Monitoring placeholders
SENTRY_DSN=
AXIOM_TOKEN=

# Additional configuration examples
SYNC_MIN_INTERVAL_SECONDS=120
APP_BASE_URL=http://localhost:8000
TRUSTED_HOSTS=localhost,127.0.0.1,*.graftai.tech
# development or production
NODE_ENV=development
# http or https
PROTOCOL=http
EXTRA_CORS_ORIGINS=https://graftai.tech,https://api.graftai.tech
LOAD_BALANCER_URL=http://localhost:8000
USAGE_FLUSH_INTERVAL_MINUTES=5
SKIP_DB_MIGRATIONS=false
SKIP_DB_REPAIR=false
DB_MIGRATION_TIMEOUT_SECONDS=60
DB_REPAIR_TIMEOUT_SECONDS=20

# Production database examples (uncomment and set for Postgres)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neondb
# REDIS_URL=redis://localhost:6379/0

# Branded Providers (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Auth0 (Optional)
AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# ── FIDO2 / WebAuthn ──
FIDO2_RP_ID=localhost
FIDO2_RP_NAME=GraftAI

# ── Monitoring & Observability ──
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.05

# ── API Security ──
TRUSTED_PROXY_IPS=
ENABLE_CIRCUIT_BREAKERS=true
FREE_TRIAL_DAYS=7

# ── Payments / Billing (Razorpay) ──
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_PLAN_PRO_ID=plan_...
RAZORPAY_PLAN_ELITE_ID=plan_...

# ── Payments / Billing (Stripe as alternative) ──
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_PRO_ID=price_...
STRIPE_PRICE_ELITE_ID=price_...

# ── Email (Resend & Gmail SMTP) ───────────────────────────────────────────────
# GraftAI uses Resend as the primary email provider (for reliability), 
# and automatically falls back to Gmail SMTP if Resend fails.
#
# Primary (Resend):
RESEND_API_KEY=your-resend-api-key

# Fallback (Gmail SMTP):
# Quick setup:
#   1. Enable 2-Step Verification on the Google account you want to use:
#      https://myaccount.google.com/security
#   2. Generate an App Password (Security → App Passwords → Mail):
#      https://myaccount.google.com/apppasswords
#   3. Fill in the values below with your Gmail address and the 16-char token.
#
# NOTE: SMTP_PASSWORD must be the App Password, NOT your Gmail login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-gmail@gmail.com
# App Password (16 chars, no spaces)
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Usually the same as SMTP_USER
SMTP_FROM_EMAIL=your-gmail@gmail.com
SMTP_FROM_NAME=GraftAI
