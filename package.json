{
  "name": "graftai-monorepo",
  "private": true,
  "scripts": {
    "dev-backend": "cd backend && .\\.venv\\Scripts\\python.exe app.py",
    "dev-frontend": "cd frontend && npm run dev",
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"bgBlue,bgGreen\" \"npm run dev-backend\" \"npm run dev-frontend\"",
    "dev-all": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "googleapis": "^171.4.0"
  }
}
