# --- GraftAI Monolith Config ---

# Core
ENV=development
DEBUG=true
PORT=8000
FRONTEND_URL=http://localhost:3000

# Security (JWT)
SECRET_KEY=generate-a-long-random-string-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 1 week

# Database
# Example: postgresql+asyncpg://user:pass@localhost:5432/graftai
DATABASE_URL=postgresql+asyncpg://

# AI & LLM
GROQ_API_KEY=
OPENAI_API_KEY=
# MODELS: llama-3.3-70b-versatile, gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# Google OAuth (Calendar Sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Microsoft OAuth (Calendar Sync)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback
