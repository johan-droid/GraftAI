# Frontend Environment Variables (Publicly available to the browser)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your_secret_here
NEXTAUTH_SECRET=your_secret_here
BACKEND_URL=http://localhost:8000

# Server-side only backend endpoints. These values must not be exposed to the browser.
# Use BACKEND_URL for the public backend endpoint in server/API routes.
# Use INTERNAL_BACKEND_URL for private/internal network calls or service-to-service traffic.
# Example values:
# BACKEND_URL=https://graftai.onrender.com
# INTERNAL_BACKEND_URL=http://backend.internal.local

# The base URL of the GraftAI Backend API.
# This should be the backend host only, without `/api/v1` appended.
# For local development:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# For production deployment, set to your rendered backend host (example):
# NEXT_PUBLIC_API_BASE_URL=https://graftai.onrender.com/api/v1
# or simply set BACKEND_URL=https://graftai.onrender.com
# Use this value to force WebSocket telemetry to the Backend host.
# If you provide a full WebSocket URL, include the path:
# NEXT_PUBLIC_WS_URL=wss://graftai.onrender.com/monitoring/ws
# Otherwise you can provide the host only:
# NEXT_PUBLIC_WS_URL=graftai.onrender.com

# The base URL of the Backend (used for direct links or specific services)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# For production deployment, set to your rendered backend host:
# NEXT_PUBLIC_BACKEND_URL=https://graftai.onrender.com

# CORS origins for backend, set in Render project env:
# CORS_ORIGINS=http://localhost:3000,https://graft-ai-two.vercel.app

# Better Auth Configuration
BETTER_AUTH_SECRET=your_secret_here
BETTER_AUTH_URL=http://localhost:3000

# Social Authentication Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
# If using Apple Auth (Optional - for automated client secret generation)
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Path to your .p8 key file
APPLE_PRIVATE_KEY_PATH=

# Zoom OAuth (Enterprise SSO)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Enterprise SSO (Generic OIDC)
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_DISCOVERY_URL=
