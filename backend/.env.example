# Backend Environment Variables Example

# ── Core API Configuration ──
ENV=development
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT=100/minute
APP_BASE_URL=http://localhost:8000

# ── Database & Persistence ──
# (Supports PostgreSQL, SQLite, etc. via SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neondb
REDIS_URL=redis://localhost:6379/0

# ── Security & Authentication ──
SECRET_KEY=generate-a-long-random-string-here
JWT_SECRET=generate-another-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_METHODS=sso,passwordless,mfa

# ── AI & LLM Orchestration ──
# Groq is the primary low-latency provider
GROQ_API_KEY=your-groq-api-key
# OpenAI fallback for complex embeddings or certain models
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ── Vector Database ──
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENV=us-west1-gcp
PINECONE_INDEX=graft-ai-index

# ── External Integrations ──
# Calendar (Cal.com)
CALCOM_API_URL=https://api.cal.com/v1
CALCOM_API_KEY=your-cal-api-key

# ── Enterprise SSO (OIDC/OAuth2) ──
# Generic OAuth2 fallback
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_AUTH_URL=https://github.com/login/oauth/authorize
OAUTH2_TOKEN_URL=https://github.com/login/oauth/access_token
OIDC_USERINFO_URL=https://api.github.com/user
OAUTH2_REDIRECT_URI=http://localhost:8000/auth/sso/callback

# Branded Providers (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# Auth0 (Optional)
AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# ── FIDO2 / WebAuthn ──
FIDO2_RP_ID=localhost
FIDO2_RP_NAME=GraftAI

# ── Monitoring & Observability ──
SENTRY_DSN=
AXIOM_TOKEN=
