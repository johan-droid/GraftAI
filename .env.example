# --- CORE ---
ENV=development
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT=100/minute
SYNC_MIN_INTERVAL_SECONDS=120
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
EXTRA_CORS_ORIGINS=https://graftai.tech,https://api.graftai.tech
LOAD_BALANCER_URL=http://localhost:8000

# --- DATABASE MANAGEMENT ---
USAGE_FLUSH_INTERVAL_MINUTES=5
SKIP_DB_MIGRATIONS=false
SKIP_DB_REPAIR=false

# --- SENTRY ---
SENTRY_DSN=

# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
FRONTEND_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require&search_path=public

# --- REDIS ---
REDIS_URL=redis://:password@localhost:6379/0

# --- SECURITY & AUTH ---
SECRET_KEY=replace-me-with-secure-random-string
JWT_SECRET=replace-me-with-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_METHODS=sso,passwordless,mfa

# Better Auth (Frontend)
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:3000

# --- AI & LLM ---
GROQ_API_KEY=replace-me
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile

# --- VECTOR DATABASE ---
PINECONE_API_KEY=replace-me
PINECONE_ENV=us-west1-gcp
PINECONE_INDEX=graftai-index

# --- EXTERNAL INTEGRATIONS ---
CALCOM_API_URL=https://api.cal.com/v1
CALCOM_API_KEY=replace-me

# --- SMTP / MAIL ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=example@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM_EMAIL=notifications@example.com
SMTP_FROM_NAME=GraftAI Notification Service
SMTP_USE_TLS=true

# Optional: SendGrid (recommended in cloud environments)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=replace-me
SENDGRID_FROM_EMAIL=verified-sender@example.com
SENDGRID_FROM_NAME=GraftAI Notification Service
# Keep false in production unless you explicitly want SMTP fallback for transient SendGrid failures.
SENDGRID_ALLOW_SMTP_FALLBACK=false

# Push notifications integration removed (OneSignal)

# --- SSO PROVIDERS ---
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
MICROSOFT_CLIENT_ID=replace-me
MICROSOFT_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:8000/auth/sso/callback
ZOOM_SCOPES="user:read:user meeting:write:meeting"

# --- FRONTEND ONLY ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- FIDO2 ---
FIDO2_RP_ID=localhost
FIDO2_RP_NAME=GraftAI Scheduler
FIDO2_ORIGIN=http://localhost:3000

# --- ZOOM ---
ZOOM_ACCOUNT_ID=replace-me
ZOOM_CLIENT_ID=replace-me
ZOOM_CLIENT_SECRET=replace-me
ZOOM_SCOPES="user:read:user meeting:write:meeting meeting:read:meeting user:read:user.settings"
ZOOM_REDIRECT_URI=http://localhost:8000/auth/zoom/callback
