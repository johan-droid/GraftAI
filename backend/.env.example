# Backend Environment Variables Example

# ── Core API Configuration ──
ENV=development
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT=100/minute
SYNC_MIN_INTERVAL_SECONDS=120
BACKEND_URL=http://localhost:8000
APP_BASE_URL=http://localhost:8000
# Backend base URL used by OAuth callbacks, health checks, and host validation.
# In production, set this to your deployed backend host, for example:
# https://graftai.onrender.com
# Legacy compatibility: APP_BASE_URL is still read by app.py when BACKEND_URL is absent.
TRUSTED_HOSTS=localhost,127.0.0.1,*.graftai.tech
# Base URL of the deployed frontend (used to redirect users after OAuth flows).
# Set this to your frontend domain in production, e.g. https://www.graftai.tech
FRONTEND_BASE_URL=http://localhost:3000
NODE_ENV=development # development or production
PROTOCOL=http # http or https
EXTRA_CORS_ORIGINS=https://graftai.tech,https://api.graftai.tech
LOAD_BALANCER_URL=http://localhost:8000

# ── Background Processes ──
# Interval at which user usage (AI counts, syncs) is flushed from Redis to DB.
USAGE_FLUSH_INTERVAL_MINUTES=5

# ── Database Management ──
SKIP_DB_MIGRATIONS=false
SKIP_DB_REPAIR=false
DB_MIGRATION_TIMEOUT_SECONDS=60
DB_REPAIR_TIMEOUT_SECONDS=20

# ── Database & Persistence ──
# (Supports PostgreSQL, SQLite, etc. via SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neondb
REDIS_URL=redis://localhost:6379/0

# ── Security & Authentication ──
SECRET_KEY=generate-a-long-random-string-here
JWT_SECRET=generate-another-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_METHODS=sso,passwordless,mfa

# ── AI & LLM Orchestration ──
# Groq is the primary low-latency provider
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
# OpenAI fallback for complex embeddings or certain models
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ── Vector Database ──
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENV=us-west1-gcp
PINECONE_INDEX=scheduler-context

# ── External Integrations ──
# Calendar (Cal.com)
CALCOM_API_URL=https://api.cal.com/v1
CALCOM_API_KEY=your-cal-api-key

# Push notifications integration removed (OneSignal)

# ── Enterprise SSO (OIDC/OAuth2) ──
# Generic OAuth2 fallback
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
OAUTH2_TOKEN_URL=https://oauth2.googleapis.com/token
OIDC_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo
# The URI that the identity provider (Google/Microsoft/Apple) redirects to after login.
# Dev: http://localhost:8000/api/v1/auth/sso/callback
# Prod: https://api.graftai.tech/api/v1/auth/sso/callback
OAUTH2_REDIRECT_URI=http://localhost:8000/api/v1/auth/sso/callback

# Branded Providers (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Auth0 (Optional)
AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=your-auth0-audience
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# ── FIDO2 / WebAuthn ──
FIDO2_RP_ID=localhost
FIDO2_RP_NAME=GraftAI

# ── Monitoring & Observability ──
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.05
AXIOM_TOKEN=

# ── API Security ──
TRUSTED_PROXY_IPS=
ENABLE_CIRCUIT_BREAKERS=true
FREE_TRIAL_DAYS=7

# ── Payments / Billing (Razorpay) ──
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_PLAN_PRO_ID=plan_...
RAZORPAY_PLAN_ELITE_ID=plan_...

# ── Payments / Billing (Stripe as alternative) ──
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_PRO_ID=price_...
STRIPE_PRICE_ELITE_ID=price_...

# ── Email (Resend & Gmail SMTP) ───────────────────────────────────────────────
# GraftAI uses Resend as the primary email provider (for reliability), 
# and automatically falls back to Gmail SMTP if Resend fails.
#
# Primary (Resend):
RESEND_API_KEY=your-resend-api-key

# Fallback (Gmail SMTP):
# Quick setup:
#   1. Enable 2-Step Verification on the Google account you want to use:
#      https://myaccount.google.com/security
#   2. Generate an App Password (Security → App Passwords → Mail):
#      https://myaccount.google.com/apppasswords
#   3. Fill in the values below with your Gmail address and the 16-char token.
#
# NOTE: SMTP_PASSWORD must be the App Password, NOT your Gmail login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx    # App Password (16 chars, no spaces)
SMTP_FROM_EMAIL=your-gmail@gmail.com # Usually the same as SMTP_USER
SMTP_FROM_NAME=GraftAI
