# =============================================================================
# GraftAI — Root .gitignore
# =============================================================================

# =============================================================================
# Python
# =============================================================================
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
__pycache__/
*.egg-info/
.eggs/

# Type-checking & linting caches
.mypy_cache/
.ruff_cache/
.pyre/

# Testing
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover
.coverage
.coverage.*
coverage/
htmlcov/

# =============================================================================
# Virtual Environments
# =============================================================================
.venv/
venv/
ENV/
env/

# =============================================================================
# Node / JavaScript
# =============================================================================
node_modules/
.pnp
.pnp.js

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
build_log*.txt

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.production
.env.production.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging

# Allow documented templates
!.env.example
!.env.template

# =============================================================================
# Databases
# =============================================================================
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
dev.db

# =============================================================================
# Logs & Temp Files
# =============================================================================
*.log
*.tmp
*.swp
*.swo
logs/
/backend/logs/

# =============================================================================
# Build Outputs
# =============================================================================
dist/
build/
target/
out/
*.min.js
*.min.css

# Frontend — Next.js
frontend/.next/
frontend/.next/cache/
frontend/out/
frontend/.cache/
frontend/.turbo/
frontend/.vercel/

# TypeScript build info
*.tsbuildinfo

# Compiled JS emitted from TypeScript source (tracked as .ts/.tsx)
frontend/src/**/*.js
frontend/src/**/*.jsx
frontend/src/**/*.js.map
frontend/public/swe-worker-*.js

# =============================================================================
# Deployment & Infra
# =============================================================================
.vercel/
.vercel
docker-compose.prod.yml
Dockerfile.prod
*.prod
*.production
*.stage
*.staging

# =============================================================================
# Uploads & User-generated content
# =============================================================================
uploads/
/backend/uploads/
/frontend/public/uploads/

# =============================================================================
# Package Manager Caches & Lockfiles
# =============================================================================
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# uv (Python package manager)
# uv.lock is intentionally committed for reproducibility; exclude only the cache
.uv/

# =============================================================================
# OS & System Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Editors & IDEs
# =============================================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# =============================================================================
# Compiled / Binary Artifacts
# =============================================================================
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# =============================================================================
# Audit, Scratch & Temporary Reports (generated during development)
# =============================================================================
*_AUDIT_REPORT.md
*_IMPLEMENTATION.md
*_FIXES_IMPLEMENTED.md
*_CHECKLIST.md
*_GUIDE.md
graftai_fullstack_audit.md
FINAL_SECURITY_FIXES.md
NPLUS1_AND_TESTING_FIXES.md
TASK_QUEUE_AND_INFRASTRUCTURE_HARDENING.md

# Test output artifacts
test_output.txt
pytest_test_results.txt

# Scratch / AI working dirs
scratch/
brain/
.gemini/

# =============================================================================
# Miscellaneous
# =============================================================================
# Root-level stray files
AuthLayout.tsx
claude.md

# Pyre configuration (type checker)
.pyre_configuration

# Python version pin (committed for tooling; ignore local overrides)
# Uncomment if you do NOT want to commit .python-version:
# .python-version
